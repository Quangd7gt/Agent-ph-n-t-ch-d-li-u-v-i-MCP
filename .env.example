PGHOST=localhost
PGPORT=5432
PGDATABASE=olist_db
PGUSER=postgres
PGPASSWORD=change_me
MAX_RETURN_ROWS=200
DEFAULT_SCHEMA=analytics
RAW_SCHEMA=raw
DATA_DIR=./data
HUGGINGFACE_TOKEN=your_token_here
GEMMA_MODEL=google/gemma-2b-it
GEMMA_DEVICE=auto
GEMMA_MAX_NEW_TOKENS=180
QUESTION_UNDERSTANDING_WITH_GEMMA=true
QUESTION_UNDERSTANDING_MAX_NEW_TOKENS=260
AGENT_API_URL=http://127.0.0.1:8000/ask
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8000
AGENT_API_PRELOAD_GEMMA=true
MCP_SHARED_URL=http://127.0.0.1:8010/mcp
MCP_HOST=127.0.0.1
MCP_PORT=8010
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_AGENT_TOOL=gemma_agent
MCP_BRIDGE_TIMEOUT=900
MCP_REQUIRE_ANTIGRAVITY_FOR_SHARED=true
MCP_ANTIGRAVITY_HEARTBEAT_TTL=8
MCP_ANTIGRAVITY_HEARTBEAT_INTERVAL=2
CHAT_SCHEMA=app
CHAT_HISTORY_LIMIT=30
